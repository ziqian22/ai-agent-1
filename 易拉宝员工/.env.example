# Running Hub API配置
RUNNINGHUB_API_KEY=your_api_key_here
RUNNINGHUB_BASE_URL=https://www.runninghub.cn/openapi/v2

# Claude API配置（用于图片分析）
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_BASE_URL=https://api.anthropic.com  # 如果使用中转服务，修改此URL

# 结果保存目录
RESULTS_DIR=./results

# Supabase Storage 配置（图片持久化）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_BUCKET=banner-images

# Cloudflare R2 对象存储配置（图片持久化）
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=banner-images
R2_PUBLIC_URL=  # 可选：自定义域名（如 https://cdn.yourdomain.com）
